<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sell Your Property - Dream Homes</title>
  <meta name="description" content="List your property for sale with Dream Homes Marketing.">
</head>
<body>
  <%- include('partials/header') %>

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card p-4 p-md-5" style="background: rgba(0,0,0,0.2); border: 1px solid var(--accent-gold); border-radius: 12px;">
          <h1 class="section-title text-center mb-4"><i class="fas fa-home me-2"></i>SELL YOUR PROPERTY WITH US</h1>
          <p class="text-white-50 text-center mb-4">Fill in the details below and our team will contact you shortly.</p>

          <div id="formAlert" class="d-none"></div>

          <form id="propertyForm" enctype="multipart/form-data">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Property Type *</label>
                <select class="form-select" name="propertyType" id="propertyType" required>
                  <option value="">Select Property Type</option>
                  <option value="house">House</option>
                  <option value="apartment">Apartment</option>
                  <option value="plot">Plot</option>
                  <option value="commercial">Commercial</option>
                  <option value="farmhouse">Farmhouse</option>
                </select>
              </div>

              <div class="col-md-6">
                <label class="form-label">Property Location *</label>
                <input type="text" class="form-control" name="propertyLocation" id="propertyLocation" placeholder="Enter property location" required>
              </div>

              <div class="col-md-6">
                <label class="form-label">Property Size *</label>
                <input type="text" class="form-control" name="propertySize" id="propertySize" placeholder="Enter Size (in Marla/Kanal)" required>
              </div>

              <div class="col-md-6">
                <label class="form-label">Asking Price (RS) *</label>
                <input type="number" class="form-control" name="askingPrice" id="askingPrice" placeholder="Enter your asking price" required min="0" step="0.01">
              </div>

              <div class="col-md-6">
                <label class="form-label">Your Full Name *</label>
                <input type="text" class="form-control" name="contactName" id="contactName" placeholder="Enter your full name" required>
              </div>

              <div class="col-md-6">
                <label class="form-label">Phone Number *</label>
                <input type="tel" class="form-control" name="contactPhone" id="contactPhone" placeholder="Enter your phone number" required>
              </div>

              <div class="col-md-6">
                <label class="form-label">Email Address</label>
                <input type="email" class="form-control" name="contactEmail" id="contactEmail" placeholder="Enter your email address">
              </div>

              <div class="col-md-6">
                <label class="form-label">Property Images *</label>
                <input type="file" class="form-control" name="propertyImages" id="propertyImages" multiple accept="image/*" required>
              </div>

              <div class="col-12">
                <label class="form-label">Property Description *</label>
                <textarea class="form-control" name="propertyDescription" id="propertyDescription" rows="4" placeholder="Describe your property in detail" required></textarea>
              </div>

              <div class="col-12 mt-4">
                <button type="submit" class="btn btn-gold btn-lg w-100" id="submitBtn">
                  <i class="fas fa-paper-plane me-2"></i>Submit Property Details
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    document.getElementById('propertyForm').addEventListener('submit', async function(e) {
      e.preventDefault();

      const form = this;
      const formData = new FormData(form);
      const submitBtn = document.getElementById('submitBtn');
      const alertDiv = document.getElementById('formAlert');

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';

      try {
        const response = await fetch('/api/properties', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        alertDiv.classList.remove('d-none', 'alert-danger', 'alert-success');

        if (response.ok) {
          alertDiv.classList.add('alert', 'alert-success');
          alertDiv.innerHTML = '<i class="fas fa-check-circle me-2"></i>' + data.message;
          form.reset();
        } else {
          alertDiv.classList.add('alert', 'alert-danger');
          alertDiv.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i>' + (data.message || 'Submission failed.');
        }
      } catch (error) {
        console.error('Submission error:', error);
        alertDiv.classList.remove('d-none');
        alertDiv.classList.add('alert', 'alert-danger');
        alertDiv.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i>An error occurred while submitting the form.';
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-paper-plane me-2"></i>Submit Property Details';
      }
    });
  </script>
</body>
</html>
