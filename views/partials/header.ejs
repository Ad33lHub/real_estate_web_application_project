<!-- Bootstrap 5 CDN + Custom Styles -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root {
    --primary-dark: rgb(23, 37, 84);
    --accent-gold: #FDE68A;
    --accent-red: #ff4d4d;
    --accent-green: #00e676;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Inter', Arial, sans-serif;
    background-color: var(--primary-dark);
    color: #fff;
  }

  /* Custom Navbar Styles */
  .navbar {
    background-color: var(--primary-dark) !important;
    border-bottom: 2px solid var(--accent-gold);
    padding: 12px 0;
  }

  .navbar-brand {
    color: var(--accent-gold) !important;
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 1px;
  }

  .navbar-nav .nav-link {
    color: #fff !important;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.5px;
    padding: 8px 15px !important;
    transition: color 0.3s ease;
  }

  .navbar-nav .nav-link:hover,
  .navbar-nav .nav-link.active {
    color: var(--accent-gold) !important;
  }

  .navbar-toggler {
    border-color: var(--accent-gold);
  }

  .navbar-toggler-icon {
    filter: brightness(0) invert(1);
  }

  .dropdown-menu {
    background-color: var(--primary-dark);
    border: 1px solid var(--accent-gold);
  }

  .dropdown-item {
    color: #fff;
  }

  .dropdown-item:hover {
    background-color: rgba(253, 230, 138, 0.1);
    color: var(--accent-gold);
  }

  /* Custom Button Styles */
  .btn-gold {
    background-color: var(--accent-gold);
    color: var(--primary-dark);
    font-weight: 600;
    border: none;
    transition: all 0.3s ease;
  }

  .btn-gold:hover {
    background-color: #f3d363;
    color: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 230, 138, 0.3);
  }

  .btn-outline-gold {
    border: 1px solid var(--accent-gold);
    color: var(--accent-gold);
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-outline-gold:hover {
    background-color: var(--accent-gold);
    color: var(--primary-dark);
  }

  /* Form Styles */
  .form-control,
  .form-select {
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--accent-gold);
    color: #fff;
    padding: 12px;
  }

  .form-control:focus,
  .form-select:focus {
    background-color: rgba(255, 255, 255, 0.12);
    border-color: var(--accent-red);
    color: #fff;
    box-shadow: 0 0 5px rgba(255, 77, 77, 0.3);
  }

  .form-control::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .form-label {
    color: var(--accent-gold);
    font-weight: 500;
  }

  /* Card Styles */
  .property-card {
    background: rgba(32, 71, 93, 0.7);
    border-radius: 12px;
    border: 1px solid rgba(255, 77, 77, 0.2);
    backdrop-filter: blur(5px);
    overflow: hidden;
    transition: all 0.4s ease;
  }

  .property-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 25px rgba(255, 77, 77, 0.3);
    border-color: var(--accent-red);
  }

  .property-card .card-img-top {
    height: 200px;
    object-fit: cover;
  }

  .property-card .card-title {
    color: var(--accent-red);
    font-weight: 600;
  }

  .property-card .price {
    color: var(--accent-green);
    font-weight: 700;
    font-size: 1.1rem;
  }

  /* Section heading */
  .section-title {
    color: var(--accent-gold);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Alert messages */
  .alert-custom {
    background-color: rgba(253, 230, 138, 0.1);
    border: 1px solid var(--accent-gold);
    color: var(--accent-gold);
  }
</style>

<nav class="navbar navbar-expand-lg navbar-dark sticky-top">
  <div class="container">
    <a class="navbar-brand" href="/">
